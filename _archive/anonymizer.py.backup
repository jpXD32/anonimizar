            'gael', 'mauricio', 'valentÃ­n', 'valentin', 'iker', 'jorge', 'ricardo',
            'alberto', 'alonso', 'cristian', 'julian', 'cÃ©sar', 'cesar', 'damiÃ¡n', 'damian',
            'fÃ©lix', 'felix', 'hector', 'kevin', 'isaÃ­as', 'isaias', 'raÃºl', 'raul',
            'esteban', 'simÃ³n', 'simon', 'alfonso', 'armando', 'darÃ­o', 'dario',
            'fabio', 'felipe', 'gustavo', 'jacobo', 'leandro', 'marcos', 'mario',
            'mÃ¡ximo', 'maximo', 'Ã³scar', 'oscar', 'patricio', 'pedro', 'rey', 'romeo',
            'rubÃ©n', 'ruben', 'saÃºl', 'sergio', 'valentino', 'vÃ­ctor', 'victor',
            'yago', 'yahir', 'zacarÃ­as', 'zacarias', 'baltasar', 'casimiro',
            'demetrio', 'edmundo',
            # Apellidos comunes chilenos - Top 100 segÃºn Registro Civil Chile
            # Incluye variantes con/sin acentos (para detectar apellidos solos)
            # Fuente: Wikipedia + CNN Chile + PsicologÃ­a y Mente
            'barrÃ­a', 'barria', 'pÃ©rez', 'perez', 'garcÃ­a', 'garcia', 'hernÃ¡ndez', 'hernandez',
            'martÃ­nez', 'martinez', 'bascuÃ±Ã¡n', 'bascunan', 'pÃ­a', 'pia',
            'gonzalez', 'muÃ±oz', 'rojas', 'diaz', 'soto', 'contreras',
